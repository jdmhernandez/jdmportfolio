---
// Assets
import Logo from "@/components/assets/Logo.astro";
import GlitchProfile from "@/components/landing/GlitchProfile.astro";
import HeroBackdrop from "@/components/landing/HeroBackdrop.astro";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ThemeToggle from "@/components/fundations/elements/ThemeToggle.astro";
---

<section>
  <Wrapper variant="standard" class="pt-6 sm:pt-8 flex flex-col justify-between min-h-dvh">
    {/* Navigation - Mobile-friendly with adequate touch targets */}
    <div class="flex flex-col lg:flex-row lg:justify-between items-start gap-6 lg:gap-8">
      <Text tag="h1" variant="display4XL" class="text-black dark:text-white font-bold order-last lg:order-first">
        Justin Hernandez
      </Text>
      <nav class="flex gap-1 sm:gap-2 items-center w-full lg:w-fit justify-between lg:justify-end">
        <div class="flex flex-col items-center gap-1">
          <ThemeToggle />
          <Text
            tag="p"
            variant="textXS"
            class="hidden sm:block max-w-[8.5rem] text-center text-base-500 dark:text-base-500 leading-tight"
          >
            Dark by default. Light mode is opt-in, like cardio.
          </Text>
        </div>
        <div class="flex gap-1 sm:gap-2">
          <a
            href="#projects"
            class="px-3 py-2 sm:px-4 sm:py-2.5 text-xs font-bold uppercase text-base-900 dark:text-base-100 hover:text-accent-500 dark:hover:text-accent-400 transition-colors rounded-lg hover:bg-base-100 dark:hover:bg-base-800"
          >
            Work
          </a>
          <a
            href="#contact"
            class="px-3 py-2 sm:px-4 sm:py-2.5 text-xs font-bold uppercase text-base-900 dark:text-base-100 hover:text-accent-500 dark:hover:text-accent-400 transition-colors rounded-lg hover:bg-base-100 dark:hover:bg-base-800"
          >
            Contact
          </a>
        </div>
      </nav>
    </div>

    {/* Hero Image Section */}
    <div class="flex justify-center items-center py-12 sm:py-16 relative">
      <div class="hero-portrait-wrap relative z-10 mx-auto">
        <HeroBackdrop />
        <GlitchProfile />
      </div>
    </div>

    <style>
      .hero-portrait-wrap {
        width: min(100%, 22rem);
        padding: 0 0.5rem;
        overflow: visible;
      }

      @media (min-width: 640px) {
        .hero-portrait-wrap {
          width: auto;
          padding: 0;
        }
      }
    </style>

    {/* Bottom Section with Tagline */}
    <div
      class="grid grid-cols-1 gap-4 md:grid-cols-3 border-b pb-6 sm:pb-8 border-base-200 dark:border-base-700"
    >
      <div>
        <Text
          tag="p"
          variant="textXS"
          class="text-base-900 dark:text-base-100 font-bold uppercase"
        >
          Aspiring IT Developer
        </Text>
      </div>
      <div class="lg:col-span-2">
        <Text tag="p" variant="textSM" class="text-base-600 dark:text-base-400 leading-relaxed">
          Hey, I'm Justin Hernandez (Jdev). Weekdays I'm a pump mechanic, weekends I'm behind the
          espresso bar, and in between I'm actively chasing a career in IT. NAIT Digital Media &
          IT graduate, recently through the Philippines, Korea, and Japan, still building projects
          and looking for the right dev role. I care about sites that feel as good as they look.
        </Text>
      </div>
    </div>
  </Wrapper>
</section>
