---
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const games = [
  {
    title: "Ys: The Oath in Felghana",
    tag: "Playing now",
    note: "Fast combat, great soundtrack, perfect handheld session after a long shift.",
  },
  {
    title: "Metal Gear Solid: Peace Walker",
    tag: "Emulated",
    note: "Stealth missions on the Vita screen. Still hits every time.",
  },
  {
    title: "PS Vita videos",
    tag: "Coming soon",
    note: "Planning retro game content and Vita-focused videos. Stay tuned.",
  },
];
---

<section class="reveal" id="vita">
  <Wrapper variant="standard">
    <div
      class="grid grid-cols-1 gap-4 md:grid-cols-3 border-b py-8 border-base-200 dark:border-base-700"
    >
      <div class="lg:sticky lg:top-24 lg:z-40 self-start">
        <Text
          tag="h2"
          variant="textSM"
          class="text-base-900 dark:text-base-100 font-bold uppercase"
        >
          Vita & Retro
        </Text>
        <Text tag="p" variant="textXS" class="mt-3 text-base-600 dark:text-base-400 leading-relaxed">
          Off the clock I unwind with my PS Vita. Retro JRPGs, emulation, and video ideas in the
          works.
        </Text>
      </div>
      <div class="lg:col-span-2 space-y-4">
        <div
          class="relative overflow-hidden rounded-xl border border-base-200 dark:border-base-700 bg-gradient-to-br from-base-900 via-base-800 to-accent-900 p-6 sm:p-8"
        >
          <div
            class="absolute inset-0 opacity-20 pointer-events-none"
            style="background-image: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(255,255,255,0.04) 2px, rgba(255,255,255,0.04) 4px)"
          >
          </div>
          <div class="relative flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <p class="text-[10px] uppercase tracking-[0.25em] text-accent-300 font-bold mb-2">
                Handheld corner
              </p>
              <Text tag="h3" variant="textSM" class="text-white font-bold uppercase">
                PlayStation Vita
              </Text>
              <Text tag="p" variant="textXS" class="mt-2 text-base-300 max-w-md leading-relaxed">
                My go-to for retro sessions. Building toward Vita content while I keep pushing my
                dev skills on the side.
              </Text>
            </div>
            <div
              class="shrink-0 w-20 h-20 sm:w-24 sm:h-24 rounded-2xl border border-accent-400/40 bg-accent-600/20 flex items-center justify-center text-3xl sm:text-4xl shadow-lg shadow-accent-900/50"
              aria-hidden="true"
            >
              🎮
            </div>
          </div>
        </div>

        {
          games.map((game) => (
            <article class="group rounded-xl border border-base-200 dark:border-base-700 bg-base-50 dark:bg-base-900/50 p-5 hover:border-accent-400/50 dark:hover:border-accent-500/40 transition-colors">
              <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
                <Text tag="h3" variant="textSM" class="text-base-900 dark:text-base-100 font-bold">
                  {game.title}
                </Text>
                <span class="text-[10px] uppercase tracking-wider font-bold px-2.5 py-1 rounded-full bg-accent-100 dark:bg-accent-900/40 text-accent-700 dark:text-accent-300">
                  {game.tag}
                </span>
              </div>
              <Text tag="p" variant="textXS" class="text-base-600 dark:text-base-400 leading-relaxed">
                {game.note}
              </Text>
            </article>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
